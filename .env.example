# Supabase — get from https://app.supabase.com/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google OAuth — get from https://console.cloud.google.com
# Create OAuth 2.0 credentials for iOS and Android clients
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=your-android-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=your-web-client-id.apps.googleusercontent.com

# TheSportsDB — https://www.thesportsdb.com/api.php
# Free tier key: "3" (test key, rate limited)
# Paid key for production use
EXPO_PUBLIC_THESPORTSDB_API_KEY=3

# ESPN API — no key required for public endpoints
# ESPN_API_BASE is hardcoded in lib/espnApi.ts

# Optional: Sentry for crash reporting
# EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn
