{
  "name": "sports-bracket-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "deploy": "expo export --platform web && touch dist/.nojekyll && cp dist/index.html dist/404.html && rm -rf dist/.git && cd dist && git init -b gh-pages && git add -A --force && git commit -m 'Deploy' && git push --force https://github.com/zachgoldberg5-jpg/sports-bracket-app.git gh-pages"
  },
